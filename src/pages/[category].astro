---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import {
  CATEGORY_INFO,
  CATEGORY_KEYS,
  type CategoryKey,
  formatDisplayDate,
  getPostCategory,
  getPostUrl,
} from '../utils/site';

export async function getStaticPaths() {
  return CATEGORY_KEYS.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;

if (!CATEGORY_KEYS.includes(category as CategoryKey)) {
  return Astro.redirect('/404');
}

const currentCategoryKey = category as CategoryKey;
const currentCategory = CATEGORY_INFO[currentCategoryKey];

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts
  .filter(post => getPostCategory(post) === currentCategoryKey)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(sortedPosts.flatMap(post => post.data.tags || []))];
const fallbackLogoClass = "w-full h-full object-contain p-4 sm:p-6";
---

<Layout
  title={`${currentCategory.title} - NSSA`}
  description={currentCategory.description}
  schemaType="CollectionPage"
  breadcrumbs={[{ name: currentCategory.title, url: `/${currentCategoryKey}/` }]}
>
  <main class="max-w-6xl mx-auto px-6 py-8">
    <header class="mb-12">
      <nav class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        <a href="/" class="hover:text-apple-blue transition-colors">Home</a>
        <span class="mx-2">→</span>
        <span class="text-gray-900 dark:text-white">{currentCategory.title}</span>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <span class="text-4xl">{currentCategory.icon}</span>
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">
            {currentCategory.title}
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-300">
            {currentCategory.description}
          </p>
        </div>
      </div>

      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <p class="text-gray-500 dark:text-gray-400">
          {sortedPosts.length} articles total
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <select
            id="tag-filter"
            class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-apple-blue"
          >
            <option value="">All Tags</option>
            {allTags.map((tag) => (
              <option value={tag}>{tag}</option>
            ))}
          </select>

          <select
            id="sort-filter"
            class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-apple-blue"
          >
            <option value="date-desc">Latest First</option>
            <option value="date-asc">Oldest First</option>
            <option value="title-asc">Title A-Z</option>
            <option value="title-desc">Title Z-A</option>
          </select>
        </div>
      </div>
    </header>

    <div id="articles-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedPosts.map((post) => {
        const thumbnail = post.data.image;
        return (
          <article
            class="content-card group article-item"
            data-tags={JSON.stringify(post.data.tags || [])}
            data-date={post.data.date.toISOString()}
            data-title={post.data.title}
          >
            <a href={getPostUrl(post)} class="block p-5 hover:no-underline">
              <div class="mb-4 rounded-xl overflow-hidden aspect-[5/2] bg-gray-100 dark:bg-gray-800">
                {thumbnail ? (
                  <img
                    src={thumbnail}
                    alt={post.data.title}
                    class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gray-50 dark:bg-gray-800/50">
                    <img src="/nssa-logo-light.svg" alt="NSSA" class={`${fallbackLogoClass} dark:hidden`} />
                    <img src="/nssa-logo-dark.svg" alt="NSSA" class={`${fallbackLogoClass} hidden dark:block`} />
                  </div>
                )}
              </div>

              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags?.slice(0, 3).map((tag) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
                    #{tag}
                  </span>
                ))}
              </div>

              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-apple-blue transition-colors line-clamp-2">
                {post.data.title}
              </h2>

              {post.data.description && (
                <p class="text-gray-600 dark:text-gray-300 text-sm mb-3 line-clamp-2">
                  {post.data.description}
                </p>
              )}

              <div class="flex items-center justify-between text-xs text-gray-400 dark:text-gray-500">
                <time datetime={post.data.date.toISOString()}>
                  {formatDisplayDate(post.data.date, post.data.lang)}
                </time>
                <span class="text-apple-blue group-hover:translate-x-1 transition-transform">
                  Read More →
                </span>
              </div>
            </a>
          </article>
        );
      })}
    </div>

    <div id="no-results" class="hidden text-center py-12">
      <div class="text-gray-400 dark:text-gray-500 mb-4">
        <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.467-.881-6.08-2.33"/>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No matching articles found</h3>
      <p class="text-gray-500 dark:text-gray-400">Try adjusting your filter criteria</p>
    </div>
  </main>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement | null;
    const sortFilter = document.getElementById('sort-filter') as HTMLSelectElement | null;
    const noResults = document.getElementById('no-results');
    if (!tagFilter || !sortFilter || !noResults) return;

    const tagSelect = tagFilter;
    const sortSelect = sortFilter;
    const noResultsEl = noResults;

    function filterAndSortArticles() {
      const selectedTag = tagSelect.value;
      const sortOption = sortSelect.value;
      const articles = Array.from(document.querySelectorAll<HTMLElement>('.article-item'));

      const filteredArticles = articles.filter(article => {
        if (!selectedTag) return true;
        const articleTags = JSON.parse(article.dataset.tags || '[]');
        return articleTags.includes(selectedTag);
      });

      filteredArticles.sort((a, b) => {
        switch (sortOption) {
          case 'date-desc':
            return new Date(b.dataset.date || '').getTime() - new Date(a.dataset.date || '').getTime();
          case 'date-asc':
            return new Date(a.dataset.date || '').getTime() - new Date(b.dataset.date || '').getTime();
          case 'title-asc':
            return (a.dataset.title || '').localeCompare(b.dataset.title || '');
          case 'title-desc':
            return (b.dataset.title || '').localeCompare(a.dataset.title || '');
          default:
            return 0;
        }
      });

      articles.forEach(article => {
        article.style.display = 'none';
      });

      if (filteredArticles.length > 0) {
        filteredArticles.forEach(article => {
          article.style.display = 'block';
        });
        noResultsEl.classList.add('hidden');
      } else {
        noResultsEl.classList.remove('hidden');
      }
    }

    tagSelect.addEventListener('change', filterAndSortArticles);
    sortSelect.addEventListener('change', filterAndSortArticles);
  });
  </script>
</Layout>
