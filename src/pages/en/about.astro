---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="About - NSSA"
  description="NSSA - Network / Systems / Security / AI"
  lang="en"
>
  <main class="max-w-4xl mx-auto px-6 py-8">
    <header class="mb-12">
      <nav class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        <a href="/en" class="hover:text-apple-blue transition-colors">Home</a>
        <span class="mx-2">→</span>
        <span class="text-gray-900 dark:text-white">About</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
        About NSSA
      </h1>

      <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
        Network / Systems / Security / AI
      </p>
    </header>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">What We Do</h2>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
          NSSA deconstructs complex systems with first principles — from technical architecture to business logic, from organizational behavior to cognitive models.
        </p>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
          Our content spans five core areas — Business, Technology, Psychology, Workplace, and History — interwoven threads that form the complex systems we live and work in.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">Content Areas</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">📊</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Business</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              In-depth business analysis and market insights, exploring business model innovation and corporate strategy
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">🔬</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Technology</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Exploring cutting-edge technology, analyzing tech trends, and studying technology's impact on society
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">🧠</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Psychology</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Psychological research and behavioral analysis, exploring human psychological phenomena and behavioral patterns
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">💼</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Workplace</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Workplace dynamics and organizational behavior research, mastering workplace survival wisdom
            </p>
          </div>
        </div>

        <div class="content-card p-5 max-w-md">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">📚</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">History</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            In-depth historical research and analysis, drawing wisdom and insights from history
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">Contact</h2>
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-gray-800 dark:to-gray-700 rounded-lg p-6">
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            If you have any suggestions or ideas, feel free to reach out:
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-center text-gray-600 dark:text-gray-300">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0 9c-1.657 0-3-4.03-3-9s1.343-9 3-9m0 18c1.657 0 3-4.03 3-9s-1.343-9-3-9m-9 9a9 9 0 019-9"/>
              </svg>
              <span>Website: nssa.io</span>
            </div>
            <a href="https://x.com/bawan269" target="_blank" rel="noopener noreferrer" class="flex items-center text-gray-600 dark:text-gray-300 hover:text-apple-blue dark:hover:text-blue-400 transition-colors">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span>X: @bawan269</span>
            </a>
            <div class="flex items-center text-gray-600 dark:text-gray-300">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zM14.53 13.39c.535 0 .969.44.969.983a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.544.434-.983.97-.983zm4.844 0c.535 0 .969.44.969.983a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.544.434-.983.97-.983zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 00.029-.463.33.33 0 00-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 00-.232-.095z"/>
              </svg>
              <span>WeChat Official Account: 大尹隐于网</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>
