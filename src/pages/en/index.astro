---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.lang === 'en' && !data.draft;
});

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latestPosts = sortedPosts.slice(0, 6);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<Layout
  title="NSSA - Network / Systems / Security / AI"
  description="Deconstructing complex systems with first principles — from technical architecture to business logic, from organizational behavior to cognitive models"
  lang="en"
>
  <main>
    <!-- Hero Section -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="text-center mb-20">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-light text-gray-900 dark:text-white tracking-tight mb-8">
          NSSA
        </h1>
        <p class="text-xl sm:text-2xl text-apple-gray font-normal max-w-4xl mx-auto leading-relaxed mb-6">
          Network / Systems / Security / AI
        </p>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
          Deconstructing complex systems with first principles — from technical architecture to business logic, from organizational behavior to cognitive models
        </p>
      </div>

      <!-- Category Cards -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 mb-20">
        <a href="/en/business/" class="content-card group block p-4 sm:p-5 text-center">
          <div class="text-2xl mb-2">📊</div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors">
            Business
          </h3>
        </a>

        <a href="/en/tech/" class="content-card group block p-4 sm:p-5 text-center">
          <div class="text-2xl mb-2">🔬</div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors">
            Technology
          </h3>
        </a>

        <a href="/en/psychology/" class="content-card group block p-4 sm:p-5 text-center">
          <div class="text-2xl mb-2">🧠</div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors">
            Psychology
          </h3>
        </a>

        <a href="/en/workplace/" class="content-card group block p-4 sm:p-5 text-center">
          <div class="text-2xl mb-2">💼</div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors">
            Workplace
          </h3>
        </a>

        <a href="/en/history/" class="content-card group block p-4 sm:p-5 text-center col-span-2 sm:col-span-1">
          <div class="text-2xl mb-2">📚</div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors">
            History
          </h3>
        </a>
      </div>

      <!-- Latest Articles -->
      <div class="mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-8">Latest Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestPosts.map((post) => (
            <a
              href={`/en/posts/${post.slug}/`}
              class="content-card group block p-6 hover:no-underline"
            >
              {post.data.image && (
                <div class="mb-4 rounded-lg overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-200"
                  />
                </div>
              )}

              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags?.slice(0, 3).map((tag) => (
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
                    #{tag}
                  </span>
                ))}
              </div>

              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                {post.data.title}
              </h3>

              {post.data.description && (
                <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-3 mb-3">
                  {post.data.description}
                </p>
              )}

              <div class="text-xs text-gray-500 dark:text-gray-400">
                {formatDate(post.data.date)}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>
</Layout>
