---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.lang === 'en' && !data.draft;
});

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryConfig = [
  { key: 'tech', label: 'Technology', icon: 'tech' },
  { key: 'business', label: 'Business', icon: 'business' },
  { key: 'psychology', label: 'Psychology', icon: 'psychology' },
  { key: 'workplace', label: 'Workplace', icon: 'workplace' },
  { key: 'history', label: 'History', icon: 'history' },
];

const categories: Record<string, typeof sortedPosts> = {};
for (const cat of categoryConfig) {
  categories[cat.key] = sortedPosts.filter(post => {
    return post.data.categories?.includes(cat.key) || post.slug.startsWith(cat.key + '/');
  }).slice(0, 3);
}

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};

function extractLastImage(body, slug) {
  if (!body) return null;
  const matches = [...body.matchAll(/!\[.*?\]\((.*?)\)/g)];
  if (matches.length === 0) return null;
  const src = matches[matches.length - 1][1];
  if (src.startsWith('./')) return `/en/posts/${slug}/${src.slice(2)}`;
  if (src.startsWith('/') || src.startsWith('http')) return src;
  return `/en/posts/${slug}/${src}`;
}
---

<Layout
  title="NSSA - Network / Systems / Security / AI"
  description="Deconstructing complex systems with first principles"
  lang="en"
>
  <main>
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="text-center mb-12">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-light text-gray-900 dark:text-white tracking-tight mb-6">
          NSSA
        </h1>
        <p class="text-xl sm:text-2xl text-apple-gray font-normal max-w-4xl mx-auto leading-relaxed mb-4">
          Network / Systems / Security / AI
        </p>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
          Deconstructing complex systems with first principles — from technical architecture to business logic, from organizational behavior to cognitive models
        </p>
      </div>

      <div class="mb-8 flex justify-center">
        <div class="inline-flex items-center gap-2 bg-gray-100 dark:bg-gray-800/50 rounded-full p-1.5 overflow-x-auto" id="category-tabs-en">
          {categoryConfig.map((cat, i) => (
            <button
              data-tab={cat.key}
              class={`tab-btn px-6 py-2.5 text-base font-medium whitespace-nowrap rounded-full transition-all ${i === 0 ? 'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-white/60 dark:hover:bg-gray-700/50'}`}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      {categoryConfig.map((cat, i) => (
        <div
          data-panel={cat.key}
          class={`tab-panel ${i === 0 ? '' : 'hidden'}`}
        >
          {categories[cat.key] && categories[cat.key].length > 0 ? (
            <div class="space-y-4">
              {categories[cat.key].map((post) => {
                const thumbnail = post.data.image || extractLastImage(post.body, post.slug);
                return (
                <a
                  href={`/en/posts/${post.slug}/`}
                  class="flex flex-col sm:flex-row gap-5 p-5 rounded-2xl border border-gray-100 dark:border-gray-700/50 hover:shadow-lg hover:shadow-gray-200/50 dark:hover:shadow-black/20 transition-all group"
                >
                  <div class="sm:w-48 sm:min-w-[192px] flex-shrink-0">
                    <div class="aspect-[16/10] rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-800">
                      {thumbnail ? (
                        <img
                          src={thumbnail}
                          alt={post.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14"/>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                          </svg>
                        </div>
                      )}
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors line-clamp-2 mb-2">
                      {post.data.title}
                    </h3>
                    {post.data.description && (
                      <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2 mb-3">
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                      <span>{formatDate(post.data.date)}</span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <>
                          <span class="text-gray-300 dark:text-gray-600">|</span>
                          <div class="flex gap-1">
                            {post.data.tags.slice(0, 2).map((tag) => (
                              <span class="px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
                                {tag}
                              </span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              );})}
            </div>
          ) : (
            <div class="text-center py-12 text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800/30 rounded-2xl">
              No articles yet
            </div>
          )}
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  const tabs = document.querySelectorAll('#category-tabs-en .tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('bg-white', 'dark:bg-gray-700', 'text-gray-900', 'dark:text-white', 'shadow-sm');
        t.classList.add('text-gray-500', 'dark:text-gray-400');
      });

      tab.classList.remove('text-gray-500', 'dark:text-gray-400');
      tab.classList.add('bg-white', 'dark:bg-gray-700', 'text-gray-900', 'dark:text-white', 'shadow-sm');

      panels.forEach(p => p.classList.add('hidden'));
      document.querySelector(`[data-panel="${key}"]`)?.classList.remove('hidden');
    });
  });
</script>
