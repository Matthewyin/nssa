---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="关于 - NSSA"
  description="NSSA - Network / Systems / Security / AI"
>
  <main class="max-w-4xl mx-auto px-6 py-8">
    <!-- Page Header -->
    <header class="mb-12">
      <nav class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        <a href="/" class="hover:text-apple-blue transition-colors">首页</a>
        <span class="mx-2">→</span>
        <span class="text-gray-900 dark:text-white">关于</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
        关于 NSSA
      </h1>

      <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
        Network / Systems / Security / AI
      </p>
    </header>

    <!-- Content -->
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">我们在做什么</h2>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
          NSSA 用第一性原理拆解复杂系统，从技术架构到商业逻辑，从组织行为到认知模型，提供深度分析和清晰洞察。
        </p>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
          内容涵盖五个核心领域——业务、技术、心理、职场、历史——它们相互交织，共同构成了我们生活和工作的复杂系统。
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">内容领域</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">📊</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">业务专题</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              深度商业分析与市场洞察，探索商业模式创新与企业战略
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">🔬</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">技术专题</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              探索前沿技术、分析技术趋势、研究技术对社会的影响
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">🧠</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">心理专题</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              心理学研究与行为分析，探索人类心理现象和行为模式
            </p>
          </div>

          <div class="content-card p-5">
            <div class="flex items-center mb-3">
              <span class="text-2xl mr-3">💼</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">职场专题</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              职场动力学与组织行为研究，掌握职场生存智慧
            </p>
          </div>
        </div>

        <div class="content-card p-5 max-w-md">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">📚</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">历史专题</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            深度历史研究与分析，从历史中汲取智慧和启示
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">联系方式</h2>
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-gray-800 dark:to-gray-700 rounded-lg p-6">
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            如果你对内容有任何建议或想法，欢迎通过以下方式联系：
          </p>
          <div class="flex flex-col gap-3">
            <div class="flex items-center text-gray-600 dark:text-gray-300">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0 9c-1.657 0-3-4.03-3-9s1.343-9 3-9m0 18c1.657 0 3-4.03 3-9s-1.343-9-3-9m-9 9a9 9 0 019-9"/>
              </svg>
              <span>网站：nssa.io</span>
            </div>
            <a href="https://x.com/bawan269" target="_blank" rel="noopener noreferrer" class="flex items-center text-gray-600 dark:text-gray-300 hover:text-apple-blue dark:hover:text-blue-400 transition-colors">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span>X：@bawan269</span>
            </a>
            <div class="flex items-center text-gray-600 dark:text-gray-300">
              <svg class="w-5 h-5 mr-3 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zM14.53 13.39c.535 0 .969.44.969.983a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.544.434-.983.97-.983zm4.844 0c.535 0 .969.44.969.983a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.544.434-.983.97-.983z"/>
              </svg>
              <span>公众号：大尹隐于网</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>
