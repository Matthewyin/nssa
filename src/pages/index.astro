---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.lang === 'zh' && !data.draft;
});

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryConfig = [
  { key: 'tech', label: '技术', icon: 'tech' },
  { key: 'business', label: '业务', icon: 'business' },
  { key: 'psychology', label: '心理', icon: 'psychology' },
  { key: 'workplace', label: '职场', icon: 'workplace' },
  { key: 'history', label: '历史', icon: 'history' },
];

const categories: Record<string, typeof sortedPosts> = {};
for (const cat of categoryConfig) {
  categories[cat.key] = sortedPosts.filter(post => {
    return post.data.categories?.includes(cat.key) || post.slug.startsWith(cat.key + '/');
  }).slice(0, 3);
}

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<Layout title="NSSA - Network / Systems / Security / AI">
  <main>
    <!-- Hero Section -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="text-center mb-16">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-light text-gray-900 dark:text-white tracking-tight mb-6">
          NSSA
        </h1>
        <p class="text-xl sm:text-2xl text-apple-gray font-normal max-w-4xl mx-auto leading-relaxed mb-4">
          Network / Systems / Security / AI
        </p>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
          用第一性原理拆解复杂系统——从技术架构到商业逻辑，从组织行为到认知模型
        </p>
      </div>

      <!-- Category Tabs -->
      <div class="mb-6">
        <div class="flex items-center gap-1 border-b border-gray-200 dark:border-gray-700 overflow-x-auto" id="category-tabs">
          {categoryConfig.map((cat, i) => (
            <button
              data-tab={cat.key}
              class={`tab-btn flex items-center gap-2 px-4 py-3 text-sm font-medium whitespace-nowrap border-b-2 transition-colors ${i === 0 ? 'text-apple-blue dark:text-blue-400 border-apple-blue dark:border-blue-400' : 'text-gray-500 dark:text-gray-400 border-transparent hover:text-gray-700 dark:hover:text-gray-300'}`}
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {cat.icon === 'tech' && <><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></>}
                {cat.icon === 'business' && <><path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 5-9"/></>}
                {cat.icon === 'psychology' && <><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></>}
                {cat.icon === 'workplace' && <><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></>}
                {cat.icon === 'history' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
              </svg>
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Tab Content -->
      {categoryConfig.map((cat, i) => (
        <div
          data-panel={cat.key}
          class={`tab-panel ${i === 0 ? '' : 'hidden'}`}
        >
          {categories[cat.key] && categories[cat.key].length > 0 ? (
            <div class="space-y-4">
              {categories[cat.key].map((post) => (
                <a
                  href={`/posts/${post.slug}/`}
                  class="flex flex-col sm:flex-row gap-4 p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-md transition-all group"
                >
                  <div class="sm:w-48 sm:min-w-[192px] flex-shrink-0">
                    <div class="aspect-[16/10] rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800">
                      {post.data.image ? (
                        <img
                          src={post.data.image}
                          alt={post.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14"/>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                          </svg>
                        </div>
                      )}
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors line-clamp-2 mb-2">
                      {post.data.title}
                    </h3>
                    {post.data.description && (
                      <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2 mb-3">
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                      <span>{formatDate(post.data.date)}</span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <>
                          <span class="text-gray-300 dark:text-gray-600">|</span>
                          <div class="flex gap-1">
                            {post.data.tags.slice(0, 2).map((tag) => (
                              <span class="px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
                                {tag}
                              </span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-12 text-gray-500 dark:text-gray-400">
              暂无文章
            </div>
          )}
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('text-apple-blue', 'dark:text-blue-400', 'border-apple-blue', 'dark:border-blue-400');
        t.classList.add('text-gray-500', 'dark:text-gray-400', 'border-transparent');
      });

      tab.classList.remove('text-gray-500', 'dark:text-gray-400', 'border-transparent');
      tab.classList.add('text-apple-blue', 'dark:text-blue-400', 'border-apple-blue', 'dark:border-blue-400');

      panels.forEach(p => p.classList.add('hidden'));
      document.querySelector(`[data-panel="${key}"]`)?.classList.remove('hidden');
    });
  });
</script>
