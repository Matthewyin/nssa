---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.lang === 'zh' && !data.draft;
});

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryConfig = [
  { key: 'tech', label: '技术', icon: 'tech' },
  { key: 'business', label: '业务', icon: 'business' },
  { key: 'psychology', label: '心理', icon: 'psychology' },
  { key: 'workplace', label: '职场', icon: 'workplace' },
  { key: 'history', label: '历史', icon: 'history' },
];

const categories: Record<string, typeof sortedPosts> = {};
for (const cat of categoryConfig) {
  categories[cat.key] = sortedPosts.filter(post => {
    return post.data.categories?.includes(cat.key) || post.slug.startsWith(cat.key + '/');
  }).slice(0, 8);
}

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};

const fallbackLogoClass = "w-full h-full object-contain p-4 sm:p-6";
---

<Layout title="NSSA - Network / Systems / Security / AI">
  <SEO
    title="NSSA - Network / Systems / Security / AI"
    description="用第一性原理拆解复杂系统——从技术架构到商业逻辑，从组织行为到认知模型"
    lang="zh"
  />
  <main>
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="text-center mb-12">
        <div class="mb-6">
          <img src="/nssa-logo-light.svg" alt="NSSA" class="h-20 sm:h-24 mx-auto dark:hidden" />
          <img src="/nssa-logo-dark.svg" alt="NSSA" class="h-20 sm:h-24 mx-auto hidden dark:block" />
        </div>
        <p class="text-xl sm:text-2xl text-apple-gray font-normal max-w-4xl mx-auto leading-relaxed mb-4">
          Network / Systems / Security / AI
        </p>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
          用第一性原理拆解复杂系统——从技术架构到商业逻辑，从组织行为到认知模型
        </p>
      </div>

      <!-- Category Tabs -->
      <div class="mb-8 flex justify-center">
        <div class="inline-flex items-center gap-2 bg-gray-100 dark:bg-gray-800/50 rounded-full p-1.5 overflow-x-auto" id="category-tabs">
          {categoryConfig.map((cat, i) => (
            <button
              data-tab={cat.key}
              class={`tab-btn px-6 py-2.5 text-base font-medium whitespace-nowrap rounded-full transition-all ${i === 0 ? 'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-white/60 dark:hover:bg-gray-700/50'}`}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Tab Content -->
      {categoryConfig.map((cat, i) => (
        <div
          data-panel={cat.key}
          class={`tab-panel transition-opacity duration-200 ${i === 0 ? '' : 'hidden opacity-0'}`}
        >
          {categories[cat.key] && categories[cat.key].length > 0 ? (
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              {categories[cat.key].map((post, postIdx) => {
                const thumbnail = post.data.image;
                const isFeatured = postIdx === 0;
                return (
                <a
                  href={`/posts/${post.slug}/`}
                  class={`group rounded-3xl border border-gray-100 dark:border-gray-700/50 bg-white/80 dark:bg-gray-900/40 overflow-hidden transition-all hover:shadow-xl hover:shadow-gray-200/60 dark:hover:shadow-black/30 hover:-translate-y-0.5 ${isFeatured ? 'lg:col-span-2 grid lg:grid-cols-[minmax(360px,520px)_1fr] gap-0 p-3 lg:p-4' : 'block p-4'}`}
                >
                  <div class={`${isFeatured ? 'lg:mr-6 mb-4 lg:mb-0' : 'mb-4'} w-full`}>
                    <div class={`${isFeatured ? 'rounded-2xl' : 'rounded-2xl'} aspect-[5/2] overflow-hidden bg-gray-100 dark:bg-gray-800`}>
                      {thumbnail ? (
                        <img
                          src={thumbnail}
                          alt={post.data.title}
                          class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center bg-gray-50 dark:bg-gray-800/50">
                          <img src="/nssa-logo-light.svg" alt="NSSA" class={`${fallbackLogoClass} dark:hidden`} />
                          <img src="/nssa-logo-dark.svg" alt="NSSA" class={`${fallbackLogoClass} hidden dark:block`} />
                        </div>
                      )}
                    </div>
                  </div>
                  <div class={`${isFeatured ? 'flex min-w-0 flex-col justify-center p-1 lg:p-3' : 'min-w-0'}`}>
                    <h3 class={`${isFeatured ? 'text-2xl' : 'text-lg'} font-semibold text-gray-900 dark:text-white group-hover:text-apple-blue dark:group-hover:text-blue-400 transition-colors line-clamp-2 mb-3`}>
                      {post.data.title}
                    </h3>
                    {post.data.description && (
                      <p class={`${isFeatured ? 'text-base line-clamp-3' : 'text-sm line-clamp-2'} text-gray-600 dark:text-gray-300 mb-4`}>
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
                      <span>{formatDate(post.data.date)}</span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <>
                          <span class="text-gray-200 dark:text-gray-700">|</span>
                          <div class="flex gap-1">
                            {post.data.tags.slice(0, 2).map((tag) => (
                              <span class="px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
                                {tag}
                              </span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              );})}
              <a
                href={`/${cat.key}/`}
                class="group flex min-h-[220px] flex-col items-center justify-center rounded-3xl border border-dashed border-gray-200 bg-gray-50/70 p-8 text-center transition-all hover:-translate-y-0.5 hover:border-apple-blue/40 hover:bg-blue-50/60 hover:shadow-xl hover:shadow-gray-200/60 dark:border-gray-700 dark:bg-gray-900/30 dark:hover:border-blue-400/40 dark:hover:bg-blue-950/20 dark:hover:shadow-black/30"
              >
                <span class="mb-3 text-sm font-medium text-gray-400 dark:text-gray-500">更多{cat.label}专题</span>
                <span class="text-2xl font-semibold text-gray-900 transition-colors group-hover:text-apple-blue dark:text-white dark:group-hover:text-blue-400">
                  查看更多
                </span>
                <span class="mt-4 text-sm text-gray-500 dark:text-gray-400">进入完整分类页面 →</span>
              </a>
            </div>
          ) : (
            <div class="text-center py-12 text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800/30 rounded-2xl">
              暂无文章
            </div>
          )}
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('bg-white', 'dark:bg-gray-700', 'text-gray-900', 'dark:text-white', 'shadow-sm');
        t.classList.add('text-gray-500', 'dark:text-gray-400');
      });

      tab.classList.remove('text-gray-500', 'dark:text-gray-400');
      tab.classList.add('bg-white', 'dark:bg-gray-700', 'text-gray-900', 'dark:text-white', 'shadow-sm');

      panels.forEach(p => { p.classList.add('hidden', 'opacity-0'); });
      const target = document.querySelector(`[data-panel="${key}"]`);
      if (target) {
        target.classList.remove('hidden');
        requestAnimationFrame(() => target.classList.remove('opacity-0'));
      }
    });
  });
</script>
